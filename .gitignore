# ─── Node / pnpm ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/
.yarn-integrity

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.svelte-kit/
.vite/

# ─── Tauri / Rust ─────────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/gen/
**/*.rs.bk
*.pdb

# Tauri auto-generated platform projects (only commit if you customize them).
src-tauri/gen/android/
src-tauri/gen/apple/

# ─── Tooling caches ───────────────────────────────────────────────────────────
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
.turbo/

# Bundler/test caches
.coverage/
coverage/
.nyc_output/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
lerna-debug.log*

# ─── Editors / IDEs ───────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml
*.swp
*.swo
*~
.history/

# JetBrains gradle/maven wrappers etc. that sneak in
.gradle/

# ─── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon[\r]
._*
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# ─── Env / secrets ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.crt
.envrc

# ─── App state Newt writes (per-workspace; never commit) ──────────────────────
.newt/

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.tmp.*
.history/
