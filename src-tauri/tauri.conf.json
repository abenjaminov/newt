{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Newt",
  "version": "0.0.0",
  "identifier": "dev.newt.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Newt",
        "width": 1600,
        "height": 1000,
        "minWidth": 720,
        "minHeight": 480,
        "maximized": true,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
